function launchJavaBot(ip, port, username, version, moveChoice, spamEnable, spamMsg, spamCount, reconnectChoice, suffixChoice, baseName) {
  console.log(c.cyan + `[Java] Bhej rahe hain ${username}${version ? ` (v${version})` : ' (Auto-Detecting)'}...` + c.reset)
  
  const botOptions = { host: ip, username: username, physicsEnabled: true }
  if (port) botOptions.port = port;
  if (version) botOptions.version = version;

  const bot = mineflayer.createBot(botOptions)
  
  // FIX 1: Unique Password Generator
  const botPassword = `OP_${username}@123`;
  
  bot.once('spawn', () => {
    console.log(c.green + c.bold + `✅ [Java] ${username} ne successfully join kar liya!` + c.reset)
    activeJavaBots.push(bot);
    
    // Use Unique Password for Auth Bypass
    setTimeout(() => {
      bot.chat(`/register ${botPassword} ${botPassword}`)
      setTimeout(() => bot.chat(`/login ${botPassword}`), 2000)
    }, 5000)

    // Movements
    if (moveChoice === '1') {
        setInterval(() => {
            try {
                bot.setControlState('forward', true);
                setTimeout(() => bot.setControlState('forward', false), 2000);
                bot.look(Math.random() * Math.PI * 2, 0);
            } catch(e){}
        }, 4000);
    } else if (moveChoice === '2') {
        setInterval(() => {
            try {
                bot.setControlState('jump', true);
                setTimeout(() => bot.setControlState('jump', false), 1000);
            } catch(e){}
        }, 2000);
    } else if (moveChoice === '3') {
        bot.setControlState('sneak', true);
    } else if (moveChoice === '4') {
        setInterval(() => {
            try {
                const playerFilter = (entity) => entity.type === 'player' && entity.username !== bot.username;
                const player = bot.nearestEntity(playerFilter);
                if (player) {
                    bot.lookAt(player.position.offset(0, player.height, 0));
                    bot.setControlState('forward', true);
                } else {
                    bot.setControlState('forward', false);
                }
            } catch(e){}
        }, 1000);
    }

    // Spam Module
    if (spamEnable === '1' && spamCount > 0) {
        let sent = 0;
        const spamTimer = setInterval(() => {
            if (sent >= spamCount) {
                clearInterval(spamTimer);
                return;
            }
            try { bot.chat(`${spamMsg} [${Math.floor(Math.random()*1000)}]`); } catch(e){}
            sent++;
        }, 3500); 
    }
  })

  // FIX 2: GUI Anti-Bot Verification Bypass
  bot.on('windowOpen', (window) => {
      console.log(c.yellow + c.bold + `⚠️ [Java] ${username} ko Server Verification Pop-up mila! Auto-Bypassing...` + c.reset);
      // Human-like delay of 2 seconds before clicking
      setTimeout(() => {
          try {
              // Find the first available item slot and click it
              const item = window.slots.find(i => i != null);
              if (item) {
                  bot.clickWindow(item.slot, 0, 0); // 0 = left click, 0 = single click
                  console.log(c.green + `🖱️ [Java] ${username} ne verification item par click kar diya!` + c.reset);
              }
          } catch(e) {
              console.log(c.red + `❌ Verification bypass fail: ${e.message}` + c.reset);
          }
      }, 2000);
  });

  bot.on('chat', (chatter, message) => {
      if (chatter === bot.username) return;
      console.log(c.magenta + `[GAME CHAT] ` + c.white + `${chatter}: ${message}` + c.reset);
  });

  bot.on('kicked', (reason) => {
      let reasonStr = typeof reason === 'object' ? JSON.stringify(reason) : reason;
      // Agar JSON reason me 'VERIFICATION' ya us jaisa kuch milta hai, toh clean message dikhaye
      if (reasonStr.toLowerCase().includes('verification')) {
          console.log(c.red + c.bold + `❌ [Java] ${username} ko "Bot Verification" fail hone par Kick mila!` + c.reset);
      } else {
          console.log(c.red + c.bold + `❌ [Java] ${username} ko Kick kar diya gaya: ${reasonStr}` + c.reset);
      }
  });
  
  bot.on('error', (err) => console.log(c.yellow + c.bold + `⚠️ [Java] ${username} Error: ${err.message}` + c.reset))
  
  bot.on('end', () => {
      const index = activeJavaBots.indexOf(bot);
      if (index > -1) activeJavaBots.splice(index, 1);

      if (reconnectChoice === '1') {
          const newName = generateName(baseName, suffixChoice);
          console.log(c.yellow + c.bold + `🔄 [Java] Nayi identity ke sath Auto-Reconnect ho raha hai: ${newName} (10 seconds me)...` + c.reset);
          setTimeout(() => {
              launchJavaBot(ip, port, newName, version, moveChoice, spamEnable, spamMsg, spamCount, reconnectChoice, suffixChoice, baseName);
          }, 10000);
      }
  })
}

function launchBedrockBot(ip, port, username, version, reconnectChoice, suffixChoice, baseName) {
  console.log(c.blue + `[Bedrock] Bhej rahe hain ${username}${version ? ` (v${version})` : ' (Auto-Detecting)'}...` + c.reset)
  const options = { host: ip, port: port, username: username, offline: true }
  if (version) options.version = version;
  
  const client = bedrock.createClient(options)
  
  client.on('join', () => {
    console.log(c.green + c.bold + `✅ [Bedrock] ${username} ne successfully join kar liya!` + c.reset)
  })
  
  client.on('disconnect', (packet) => {
      console.log(c.red + c.bold + `❌ [Bedrock] ${username} ko Kick kar diya gaya` + c.reset);
      if (reconnectChoice === '1') {
          const newName = generateName(baseName, suffixChoice) + "BR";
          console.log(c.yellow + c.bold + `🔄 [Bedrock] Nayi identity ke sath Auto-Reconnect ho raha hai: ${newName} (10 seconds me)...` + c.reset);
          setTimeout(() => launchBedrockBot(ip, port, newName, version, reconnectChoice, suffixChoice, baseName), 10000);
      }
  })
  client.on('error', (err) => console.log(c.yellow + c.bold + `⚠️ [Bedrock] ${username} Error: ${err.message}` + c.reset))
}

startInteractiveMenu()
