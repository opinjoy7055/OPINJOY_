      }
    } 
    
    else if (step === 3) {
      console.log(c.yellow + c.bold + 'Q3. Server IP & Port:' + c.reset)
      // FIX: Cleaned up the input message. No more unnecessary formatting text.
      console.log(c.magenta + '(Peeche jane ke liye "back" likhein)' + c.reset)
      ipInput = (await ask(c.green + c.bold + 'IP (Port ke sath ya bina)-» ' + c.reset)).trim()
      
      if (ipInput.toLowerCase() === 'back') {
        step--;
      } else if (ipInput !== "") {
        const parts = ipInput.split(':');
        parsedIp = parts[0];
        parsedPort = parts[1] ? parseInt(parts[1]) : null;
        step++;
      }
    } 
    
    else if (step === 4) {
      console.log(c.yellow + c.bold + 'Q4. Base Name & Suffix:' + c.reset)
      baseName = (await ask(c.green + c.bold + 'Bot ka Base Name-» ' + c.reset)).trim()
      if (baseName.toLowerCase() === 'back') { step--; continue; }
      
      console.log(c.cyan + '\nBots ke piche (suffix) kya lagana hai?')
      console.log('(1) Numbers | (2) Words | (3) Exact Name | (4) Number aur Words dono | (5) Back' + c.reset)
      suffixChoice = (await ask(c.green + c.bold + 'Choice-» ' + c.reset)).trim()
      
      if (suffixChoice === '5') step--;
      else if (['1','2','3','4'].includes(suffixChoice)) step++;
    } 
    
    else if (step === 5) {
      console.log(c.yellow + c.bold + 'Q5. Bot Password:' + c.reset)
      console.log(c.cyan + '(Khali chhodne par Name+Word+Number ka Unique Password auto-generate hoga) | Peeche jane k liye "back" likhein' + c.reset)
      customPassword = (await ask(c.green + c.bold + 'Password-» ' + c.reset)).trim()
      
      if (customPassword.toLowerCase() === 'back') step--;
