const activeJavaBots = [];

async function startInteractiveMenu() {
  refreshScreen()
  console.log(c.cyan + c.bold + 'Q1. Tumhe kaunse Minecraft edition ka bot chahiye?' + c.reset)
  console.log(c.yellow + '1) Java bot')
  console.log('2) Bedrock bot')
