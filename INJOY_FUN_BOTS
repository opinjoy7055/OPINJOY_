  refreshScreen()
  console.log(c.yellow + c.bold + 'Q6. Advanced Movements aur Custom Pathfinding' + c.reset)
  console.log(c.cyan + '1) Idhar-udhar ghoomein (Walk Randomly)')
  console.log('2) Uchal-kood karein (Jumping)')
  console.log('3) Baith jayein (Sneak)')
  console.log('4) Paas wale player ke piche chalein (Follow Closest Player)')
  console.log('5) Kuch nahi (Shanti se khade rahein)' + c.reset + '\n')
  const moveChoice = (await ask(c.green + c.bold + 'Choice (1-5)-» ' + c.reset)).trim()

