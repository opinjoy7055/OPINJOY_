const activeJavaBots = [];
let uniqueCounter = 1; // Global rule ke liye unique counter

function generateName(base, choice) {
    const words = ['spider', 'ninja', 'pro', 'hacker', 'god', 'titan', 'king', 'ghost', 'shadow', 'dragon', 'venom', 'wolf'];
    const rWord = words[Math.floor(Math.random() * words.length)];
    const rNum = Math.floor(1000 + Math.random() * 9000);
    
    let name = base;
    if (choice === '1') name = `${base}${rNum}`;                      // Numbers
    else if (choice === '2') name = `${base}${rWord}`;                 // Words
    else if (choice === '4') name = `${base}${rWord}${rNum}`;          // Number + Words
    else if (choice === '3') name = `${base}_${uniqueCounter}`;        // Exact name but forced unique globally

    uniqueCounter++;
    return name;
}

function generatePassword(botName) {
    const words = ['pass', 'sec', 'key', 'op', 'joy', 'bot', 'lock'];
    const rWord = words[Math.floor(Math.random() * words.length)];
    const rNum = Math.floor(1000 + Math.random() * 9000);
    return `${botName}${rWord}${rNum}`; // Auto Generate: Name + Word + Number
}

async function startInteractiveMenu() {
