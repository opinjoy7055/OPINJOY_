    } 
    
    else if (step === 6) {
      console.log(c.yellow + c.bold + 'Q6. Advanced Movements:' + c.reset)
      console.log(c.cyan + '(1) Walk Randomly | (2) Jumping+Sneak | (3) Follow Player | (4) Freeze | (5) Back' + c.reset)
      moveChoice = (await ask(c.green + c.bold + 'Choice-» ' + c.reset)).trim()
      
