  console.log(c.cyan + c.bold + 'Q2. Apna Server IP aur Port dalo (Agar default port hai toh bas Enter dabao)' + c.reset)
  const ip = (await ask(c.yellow + '1) Server IP-» ' + c.reset)).trim()
