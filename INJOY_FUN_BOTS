  if (spamEnable === '2') {
      console.log(c.green + c.bold + '💬 TERMINAL CHAT ON HAI: Yahan terminal me jo bhi type karoge, wo server me jayega!' + c.reset)
      rl.on('line', (input) => {
          if(input.trim() !== '') {
