      if(input.trim() !== '') {
          activeJavaBots.forEach(bot => {
              try { bot.chat(input); } catch(e) {}
          });
      }
  });

  let currentBot = 1;
  
  function generateName(base, choice) {
      if (choice === '2') {
          const words = ['spider', 'ninja', 'pro', 'hacker', 'god', 'titan', 'king', 'ghost', 'shadow', 'dragon', 'venom', 'wolf'];
          return `${base}${words[Math.floor(Math.random() * words.length)]}`;
      } else {
          return `${base}${Math.floor(1000 + Math.random() * 9000)}`;
      }
  }

  function spawnNextBot() {
    if (currentBot > botCount) {
      console.log(c.green + c.bold + '\n✅ Saare bots successfully server me bhej diye gaye hain!' + c.reset)
      return;
    }

    const botName = generateName(baseName, suffixChoice);

    if (editionChoice === '1' || editionChoice === '3') launchJavaBot(ip, javaPort, botName, javaVer, moveChoice, spamEnable, spamMsg, spamCount, reconnectChoice, suffixChoice, baseName);
