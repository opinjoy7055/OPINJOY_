const activeJavaBots = [];

function generateName(base, choice) {
    if (choice === '3') {
        return base; 
    } else if (choice === '2') {
        const words = ['spider', 'ninja', 'pro', 'hacker', 'god', 'titan', 'king', 'ghost', 'shadow', 'dragon', 'venom', 'wolf'];
        return `${base}${words[Math.floor(Math.random() * words.length)]}`;
    } else {
        return `${base}${Math.floor(1000 + Math.random() * 9000)}`;
    }
}

async function startInteractiveMenu() {
  refreshScreen()
  console.log(c.yellow + c.bold + 'Q1. Tumhe kaunse Minecraft edition ka bot chahiye?' + c.reset)
  console.log(c.cyan + '1) Java bot')
  console.log('2) Bedrock bot')
  console.log('3) Dono (Java + Bedrock)')
  console.log('4) Exit (Bahar niklo)' + c.reset + '\n')
  
  const editionChoice = (await ask(c.green + c.bold + 'Apna Choice batao (1-4)-» ' + c.reset)).trim()
  if (editionChoice === '4') {
    console.clear()
    console.log(c.red + c.bold + 'Script band ho rahi hai... Phir milenge! 🕷️' + c.reset)
    process.exit(0)
  }

  refreshScreen()
  console.log(c.yellow + c.bold + 'Q2. Apna Server IP aur Port dalo (Agar default port hai toh bas Enter dabao)' + c.reset)
  const ip = (await ask(c.green + c.bold + '1) Server IP-» ' + c.reset)).trim()
  const portInput = (await ask(c.green + c.bold + '2) Server Port-» ' + c.reset)).trim()
  
