      else if (moveChoice === '3') {
          targetPlayer = (await ask(c.green + c.bold + 'Kisko follow karna hai? (Player Name)-» ' + c.reset)).trim()
          step++;
      }
      else if (['1','2','4'].includes(moveChoice)) step++;
    } 
    
    else if (step === 7) {
      console.log(c.yellow + c.bold + 'Q7. Anti-Kick / Reconnect:' + c.reset)
      console.log(c.cyan + '(1) IP change per bots (Proxy Simulator) | (2) Just normal, don\'t change IP | (3) Back' + c.reset)
      reconnectChoice = (await ask(c.green + c.bold + 'Choice-» ' + c.reset)).trim()
      
      if (reconnectChoice === '3') step--;
      else if (['1','2'].includes(reconnectChoice)) step++;
    } 
    
    else if (step === 8) {
      console.log(c.yellow + c.bold + 'Q8. Joining Speed & Bypass:' + c.reset)
      console.log(c.cyan + '(1) Normal | (2) Anti-bot bypass (Safe) | (3) Ultra Speed | (4) Back' + c.reset)
      speedChoice = (await ask(c.green + c.bold + 'Choice-» ' + c.reset)).trim()
      
      if (speedChoice === '4') step--;
      else if (['1','2','3'].includes(speedChoice)) step++;
    } 
    
    else if (step === 9) {
      console.log(c.yellow + c.bold + 'Q9. Chat / Spam Module:' + c.reset)
      console.log(c.cyan + '(1) Auto Spam | (2) Terminal In-Game Chat | (3) Just joined (Silent) | (4) Back' + c.reset)
      spamEnable = (await ask(c.green + c.bold + 'Choice-» ' + c.reset)).trim()
      
      if (spamEnable === '4') step--;
      else if (spamEnable === '1') {
          spamMsg = (await ask(c.green + c.bold + 'Message kya spam karna hai?-» ' + c.reset)).trim()
          spamCount = parseInt((await ask(c.green + c.bold + 'Kitni baar bheje?-» ' + c.reset)).trim()) || 5;
          step++;
      }
      else if (['2','3'].includes(spamEnable)) step++;
    } 
    
    else if (step === 10) {
      console.log(c.yellow + c.bold + 'Q10. Bot Version:' + c.reset)
      console.log(c.cyan + '(1) Use default set version (Java: 1.21.4 | Bedrock: 1.26.30)' + c.reset)
      console.log(c.cyan + '(2) Use your needed version (Custom)' + c.reset)
      console.log(c.cyan + '(3) Back' + c.reset)
      versionChoice = (await ask(c.green + c.bold + 'Choice-» ' + c.reset)).trim()
      
