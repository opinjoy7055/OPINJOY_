async function startInteractiveMenu() {
  refreshScreen()
  console.log(c.cyan + c.bold + 'Q1. Which minecraft edition bot you need?' + c.reset)
  console.log(c.yellow + '1) Java bot')
  console.log('2) Bedrock bot')
  console.log('3) Both java+bedrock')
  console.log('4) Exit' + c.reset + '\n')
  
  const editionChoice = (await ask(c.white + c.bold + 'Choice (1-4)-┬╗ ' + c.reset)).trim()
  if (editionChoice === '4') {
    console.log(c.red + c.bold + 'Exiting script...' + c.reset)
    process.exit(0)
  }

  refreshScreen()
  console.log(c.cyan + c.bold + 'Q2. Enter & Fill your Server Ip port (If port is default, just press enter)' + c.reset)
  const ip = (await ask(c.yellow + '1) Server IP-┬╗ ' + c.reset)).trim()
  const portInput = (await ask(c.yellow + '2) Server Port-┬╗ ' + c.reset)).trim()
  
  refreshScreen()
  console.log(c.cyan + c.bold + 'Q3. Enter Bot Base Name?' + c.reset)
  const baseName = (await ask(c.yellow + '1) Bot Name-┬╗ ' + c.reset)).trim()

  refreshScreen()
  let javaVer = false;
  let bedrockVer = false;

  if (editionChoice === '1') {
    console.log(c.cyan + c.bold + 'Q4. Enter Java edition bot version? (Press Enter for Auto-Detect)' + c.reset)
    let jv = (await ask(c.yellow + '1) Java version-┬╗ ' + c.reset)).trim()
    if (jv) javaVer = jv;
  } else if (editionChoice === '2') {
    console.log(c.cyan + c.bold + 'Q4. Enter Bedrock edition bot version? (Press Enter for Auto-Detect)' + c.reset)
    let bv = (await ask(c.yellow + '1) Bedrock version-┬╗ ' + c.reset)).trim()
    if (bv) bedrockVer = bv;
  } else if (editionChoice === '3') {
    console.log(c.cyan + c.bold + 'Q4. Enter Both java+bedrock version? (Press Enter for Auto-Detect)' + c.reset)
    let jv = (await ask(c.yellow + '1) Java version-┬╗ ' + c.reset)).trim()
    let bv = (await ask(c.yellow + '2) Bedrock version-┬╗ ' + c.reset)).trim()
    if (jv) javaVer = jv;
    if (bv) bedrockVer = bv;
  }

  refreshScreen()
  console.log(c.cyan + c.bold + 'Q5. Enter how many bots you want to deploy?' + c.reset)
  const botCountInput = (await ask(c.yellow + '1) Bots number-┬╗ ' + c.reset)).trim()
  rl.close()

  refreshScreen()
  const botCount = parseInt(botCountInput) || 1
  const javaPort = portInput ? parseInt(portInput) : 25565
  const bedrockPort = portInput ? parseInt(portInput) : 19132

  console.log(c.magenta + c.bold + `ЁЯЪА Deploying ${botCount} bots to ${ip}...` + c.reset)
  console.log(c.cyan + '-----------------------------------------' + c.reset)

  let launchDelay = 0
  for (let i = 1; i <= botCount; i++) {
    const uniqueNumber = Math.floor(1000 + Math.random() * 9000)
    const botName = `${baseName}_${uniqueNumber}`

    setTimeout(() => {
      if (editionChoice === '1' || editionChoice === '3') launchJavaBot(ip, javaPort, botName, javaVer)
      if (editionChoice === '2' || editionChoice === '3') {
        if (bedrock) launchBedrockBot(ip, bedrockPort, `${botName}_BR`, bedrockVer)
      }
    }, launchDelay)
    launchDelay += 6000 
  }
}

function launchJavaBot(ip, port, username, version) {
  console.log(c.cyan + `[Java] Deploying ${username}${version ? ` (v${version})` : ' (Auto)'}...` + c.reset)
  const bot = mineflayer.createBot({ host: ip, port: port, username: username, version: version, physicsEnabled: false })
  
  bot.once('spawn', () => {
    console.log(c.green + c.bold + `тЬЕ [Java] ${username} successfully joined!` + c.reset)
    setTimeout(() => {
      bot.chat('/register OpInjoy123 OpInjoy123')
      setTimeout(() => bot.chat('/login OpInjoy123'), 2000)
    }, 5000)
  })
  bot.on('kicked', (reason) => console.log(c.red + c.bold + `тЭМ [Java] ${username} Kicked` + c.reset))
  bot.on('error', (err) => console.log(c.yellow + c.bold + `тЪая╕П [Java] ${username} Error: ${err.message}` + c.reset))
}

function launchBedrockBot(ip, port, username, version) {
  console.log(c.blue + `[Bedrock] Deploying ${username}${version ? ` (v${version})` : ' (Auto)'}...` + c.reset)
  const options = { host: ip, port: port, username: username, offline: true }
  if (version) options.version = version;
  
  const client = bedrock.createClient(options)
  
  client.on('join', () => console.log(c.green + c.bold + `тЬЕ [Bedrock] ${username} successfully joined!` + c.reset))
  client.on('disconnect', (packet) => console.log(c.red + c.bold + `тЭМ [Bedrock] ${username} Kicked` + c.reset))
  client.on('error', (err) => console.log(c.yellow + c.bold + `тЪая╕П [Bedrock] ${username} Error: ${err.message}` + c.reset))
}

startInteractiveMenu()
