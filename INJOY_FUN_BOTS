  console.log(c.yellow + c.bold + 'Q3. Bot ka Base Name aur Naming Style batao' + c.reset)
  const baseName = (await ask(c.green + c.bold + '1) Bot ka Base Name-» ' + c.reset)).trim()
  console.log(c.cyan + '\nBots ke piche (suffix) kya lagana hai?')
  console.log('1) Numbers (Jaise: ' + baseName + '7449)')
  console.log('2) Words (Jaise: ' + baseName + 'spider)')
  console.log('3) Kuch mat lagao (Exact Name: ' + baseName + ')' + c.reset)
  const suffixChoice = (await ask(c.green + c.bold + 'Choice (1-3)-» ' + c.reset)).trim()

  refreshScreen()
  let javaVer = false;
  let bedrockVer = false;

  if (editionChoice === '1' || editionChoice === '3') {
    console.log(c.yellow + c.bold + 'Q4. Java edition bot ka version dalo? (Auto-detect ke liye bas Enter dabao)' + c.reset)
    let jv = (await ask(c.green + c.bold + '1) Java version-» ' + c.reset)).trim()
    if (jv) javaVer = jv;
  }
  if (editionChoice === '2' || editionChoice === '3') {
    console.log(c.yellow + c.bold + 'Q4b. Bedrock edition bot ka version dalo? (Auto-detect ke liye bas Enter dabao)' + c.reset)
    let bv = (await ask(c.green + c.bold + '1) Bedrock version-» ' + c.reset)).trim()
    if (bv) bedrockVer = bv;
  }

  refreshScreen()
  console.log(c.yellow + c.bold + 'Q5. Deployment Mode select karo' + c.reset)
  console.log(c.cyan + '1) Limited bots (Tum batao kitne bots bhejney hain)')
  console.log('2) Unlimited bots (Bots lagatar join karenge jab tak Ctrl+C nahi dabaate)' + c.reset + '\n')
  const modeChoice = (await ask(c.green + c.bold + 'Choice (1-2)-» ' + c.reset)).trim()

  let botCount = Infinity
  if (modeChoice === '1') {
    const botCountInput = (await ask(c.green + c.bold + 'Kitne bots chahiye?-» ' + c.reset)).trim()
    botCount = parseInt(botCountInput) || 1
