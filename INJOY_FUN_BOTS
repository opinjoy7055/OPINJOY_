  console.log('2) Words (Jaise: ' + baseName + 'spider)')
  const suffixChoice = (await ask(c.white + c.bold + 'Choice (1-2)-» ' + c.reset)).trim()

  refreshScreen()
  let javaVer = false;
  let bedrockVer = false;

  if (editionChoice === '1' || editionChoice === '3') {
    console.log(c.cyan + c.bold + 'Q4. Java edition bot ka version dalo? (Auto-detect ke liye bas Enter dabao)' + c.reset)
    let jv = (await ask(c.yellow + '1) Java version-» ' + c.reset)).trim()
    if (jv) javaVer = jv;
  }
  if (editionChoice === '2' || editionChoice === '3') {
    console.log(c.cyan + c.bold + 'Q4b. Bedrock edition bot ka version dalo? (Auto-detect ke liye bas Enter dabao)' + c.reset)
    let bv = (await ask(c.yellow + '1) Bedrock version-» ' + c.reset)).trim()
    if (bv) bedrockVer = bv;
  }

  refreshScreen()
  console.log(c.cyan + c.bold + 'Q5. Deployment Mode select karo' + c.reset)
  console.log(c.yellow + '1) Limited bots (Tum batao kitne bots bhejney hain)')
  console.log('2) Unlimited bots (Bots lagatar join karenge jab tak Ctrl+C nahi dabaate)' + c.reset + '\n')
  const modeChoice = (await ask(c.white + c.bold + 'Choice (1-2)-» ' + c.reset)).trim()

  let botCount = Infinity
  if (modeChoice === '1') {
    const botCountInput = (await ask(c.yellow + 'Kitne bots chahiye?-» ' + c.reset)).trim()
    botCount = parseInt(botCountInput) || 1
  }

  refreshScreen()
  console.log(c.cyan + c.bold + 'Q6. Advanced Movements aur Custom Pathfinding' + c.reset)
  console.log(c.yellow + '1) Idhar-udhar ghoomein (Walk Randomly)')
  console.log('2) Uchal-kood karein (Jumping)')
  console.log('3) Baith jayein (Sneak)')
  console.log('4) Paas wale player ke piche chalein (Follow Closest Player)')
  console.log('5) Kuch nahi (Shanti se khade rahein)' + c.reset + '\n')
  const moveChoice = (await ask(c.white + c.bold + 'Choice (1-5)-» ' + c.reset)).trim()

  refreshScreen()
  console.log(c.cyan + c.bold + 'Q7. Global Chat Spam Module' + c.reset)
  console.log(c.yellow + '1) Chat Spam ON karo')
  console.log('2) Chat Spam OFF rakho' + c.reset + '\n')
  const spamEnable = (await ask(c.white + c.bold + 'Choice (1-2)-» ' + c.reset)).trim()
  
