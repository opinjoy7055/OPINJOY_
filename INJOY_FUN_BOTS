                  try { bot.chat(input); } catch(e) {}
              });
          }
      });
  }

  console.log(c.cyan + '-----------------------------------------' + c.reset)

  let currentBot = 1;

  // Q8: Joining Speed Calculation
  let joinDelay = 6000;
  if (speedChoice === '1') joinDelay = 6000;       // Normal
  else if (speedChoice === '2') joinDelay = 12000; // Anti-bot bypass (Safe)
  else if (speedChoice === '3') joinDelay = 2000;  // Ultra Speed

  function spawnNextBot() {
    if (currentBot > botCount) {
      console.log(c.green + c.bold + '\n✅ Saare bots successfully server me bhej diye gaye hain!' + c.reset)
      return;
    }

    const botName = generateName(baseName, suffixChoice);
    // Q5: Auto-generate password logic
    const botPassword = customPassword !== "" ? customPassword : generatePassword(botName);

    if (editionChoice === '1' || editionChoice === '3') launchJavaBot(parsedIp, javaPort, botName, javaVer, moveChoice, targetPlayer, spamEnable, spamMsg, spamCount, reconnectChoice, suffixChoice, baseName, botPassword, speedChoice);
    if (editionChoice === '2' || editionChoice === '3') {
      if (bedrock) launchBedrockBot(parsedIp, bedrockPort, `${botName}BR`, bedrockVer, reconnectChoice, suffixChoice, baseName, speedChoice);
    }

    currentBot++;
    setTimeout(spawnNextBot, joinDelay)
  }

  spawnNextBot()
}

function launchJavaBot(ip, port, username, version, moveChoice, targetPlayer, spamEnable, spamMsg, spamCount, reconnectChoice, suffixChoice, baseName, botPassword, speedChoice) {
  console.log(c.cyan + `[Java] Bhej rahe hain ${username} (v${version})...` + c.reset)
  
  const botOptions = { host: ip, username: username, physicsEnabled: true }
  if (port) botOptions.port = port;
  if (version) botOptions.version = version;

  const bot = mineflayer.createBot(botOptions)
  
  // ANTI-BOT DELAY MAPPING
  let guiDelay = 3000;
  let reconnectWait = 10000;
  
  if (speedChoice === '1') { guiDelay = 3000; reconnectWait = 10000; } // Normal
  else if (speedChoice === '2') { guiDelay = 5500; reconnectWait = 15000; } // Anti-Bot
  else if (speedChoice === '3') { guiDelay = 1000; reconnectWait = 5000; } // Ultra Speed

  let authHandled = false;
  let defaultAuthTimer = null;

  function doAuth() {
      if (authHandled) return;
      authHandled = true;
      console.log(c.magenta + `🔑 [Java] ${username} Verification pass. Auth Bypass shuru (Pass: ${botPassword})...` + c.reset);
      bot.chat(`/register ${botPassword} ${botPassword}`);
      setTimeout(() => {
          bot.chat(`/login ${botPassword}`);
      }, 2000);
  }

  bot.once('spawn', () => {
    console.log(c.green + c.bold + `✅ [Java] ${username} ne successfully join kar liya!` + c.reset);
    activeJavaBots.push(bot);
    
    defaultAuthTimer = setTimeout(() => {
        if (!authHandled) doAuth();
    }, 5000);

    // Q6: ADVANCED MOVEMENTS
    if (moveChoice === '1') { // Walk Randomly
        setInterval(() => {
            try {
                bot.setControlState('forward', true);
                setTimeout(() => bot.setControlState('forward', false), 2000);
                bot.look(Math.random() * Math.PI * 2, 0);
            } catch(e){}
        }, 4000);
    } else if (moveChoice === '2') { // Jumping + Sneak
        setInterval(() => {
            try {
                bot.setControlState('jump', true);
                bot.setControlState('sneak', true);
                setTimeout(() => { bot.setControlState('jump', false); bot.setControlState('sneak', false); }, 1000);
            } catch(e){}
        }, 2000);
    } else if (moveChoice === '3') { // Follow Player
        setInterval(() => {
            try {
                const player = bot.players[targetPlayer]?.entity;
                if (player) {
                    bot.lookAt(player.position.offset(0, player.height, 0));
                    bot.setControlState('forward', true);
                } else {
                    bot.setControlState('forward', false);
                }
            } catch(e){}
        }, 500);
    } else if (moveChoice === '4') { // Freeze
         // Do nothing, bot stands completely still.
    }

    if (spamEnable === '1' && spamCount > 0) {
        let sent = 0;
        const spamTimer = setInterval(() => {
            if (sent >= spamCount) {
                clearInterval(spamTimer);
                return;
            }
            try { bot.chat(`${spamMsg} [${Math.floor(Math.random()*1000)}]`); } catch(e){}
            sent++;
        }, 3500); 
    }
  })

  bot.on('resourcePack', (url, hash) => {
      clearTimeout(defaultAuthTimer); 
      console.log(c.yellow + c.bold + `⚠️ [Java] ${username} ko Resource Pack Pop-up mila! (${guiDelay}ms delay lag raha hai)...` + c.reset);
      setTimeout(() => {
          try {
              bot.acceptResourcePack();
              console.log(c.green + `✅ [Java] ${username} ne Resource Pack 'Yes/Verification' par click kar diya!` + c.reset);
              setTimeout(doAuth, 2000);
          } catch (e) {
              console.log(c.red + `❌ Bypass fail: ${e.message}` + c.reset);
          }
      }, guiDelay);
  });

  bot.on('windowOpen', (window) => {
      clearTimeout(defaultAuthTimer); 
      console.log(c.yellow + c.bold + `⚠️ [Java] ${username} ko GUI Pop-up mila! Bypassing in ${guiDelay}ms...` + c.reset);
      setTimeout(() => {
          try {
              let targetItem = window.slots.find(i => i != null && !i.name.includes('glass') && !i.name.includes('pane'));
              if (!targetItem) targetItem = window.slots.find(i => i != null); 
              
              if (targetItem) {
                  bot.clickWindow(targetItem.slot, 0, 0); 
                  console.log(c.green + `🖱️ [Java] ${username} ne '${targetItem.name}' par click kiya! (Slot: ${targetItem.slot})` + c.reset);
                  setTimeout(doAuth, 2000);
              }
          } catch(e) {
              console.log(c.red + `❌ GUI bypass fail: ${e.message}` + c.reset);
          }
      }, guiDelay);
  });

  bot.on('chat', (chatter, message) => {
      if (chatter === bot.username) return;
      console.log(c.magenta + `[GAME CHAT] ` + c.white + `${chatter}: ${message}` + c.reset);
  });

  bot.on('kicked', (reason) => {
      let reasonStr = typeof reason === 'object' ? JSON.stringify(reason) : reason;
      console.log(c.red + c.bold + `❌ [Java] ${username} ko Kick kar diya gaya: ${reasonStr}` + c.reset);
  });
  
  bot.on('error', (err) => console.log(c.yellow + c.bold + `⚠️ [Java] ${username} Error: ${err.message}` + c.reset))
  
  bot.on('end', () => {
      const index = activeJavaBots.indexOf(bot);
      if (index > -1) activeJavaBots.splice(index, 1);

      // Q7: Reconnect Logic
      if (reconnectChoice === '1') {
          // Change Name format completely to simulate new entity
          const newName = generateName(baseName, '4'); // Force fresh word+num
          console.log(c.yellow + c.bold + `🔄 [Java] IP/Name change simulation sath Auto-Reconnect: ${newName} (${reconnectWait/1000}s me)...` + c.reset);
          setTimeout(() => {
              launchJavaBot(ip, port, newName, version, moveChoice, targetPlayer, spamEnable, spamMsg, spamCount, reconnectChoice, suffixChoice, baseName, botPassword, speedChoice);
          }, reconnectWait);
      } else if (reconnectChoice === '2') {
          console.log(c.yellow + c.bold + `🔄 [Java] Same naam (${username}) ke sath normal Reconnect ho raha hai (${reconnectWait/1000}s me)...` + c.reset);
          setTimeout(() => {
              launchJavaBot(ip, port, username, version, moveChoice, targetPlayer, spamEnable, spamMsg, spamCount, reconnectChoice, suffixChoice, baseName, botPassword, speedChoice);
          }, reconnectWait);
      }
  })
}

function launchBedrockBot(ip, port, username, version, reconnectChoice, suffixChoice, baseName, speedChoice) {
  let reconnectWait = speedChoice === '2' ? 15000 : (speedChoice === '3' ? 5000 : 10000);
  
  console.log(c.blue + `[Bedrock] Bhej rahe hain ${username} (v${version})...` + c.reset)
  const options = { host: ip, port: port, username: username, offline: true }
  if (version) options.version = version;
  
  const client = bedrock.createClient(options)
  
  client.on('join', () => {
    console.log(c.green + c.bold + `✅ [Bedrock] ${username} ne successfully join kar liya!` + c.reset)
  })
  
  client.on('disconnect', (packet) => {
      console.log(c.red + c.bold + `❌ [Bedrock] ${username} ko Kick kar diya gaya` + c.reset);
      if (reconnectChoice === '1') {
          const newName = generateName(baseName, '4') + "BR";
          console.log(c.yellow + c.bold + `🔄 [Bedrock] IP/Name change simulation Auto-Reconnect: ${newName} (${reconnectWait/1000}s me)...` + c.reset);
          setTimeout(() => launchBedrockBot(ip, port, newName, version, reconnectChoice, suffixChoice, baseName, speedChoice), reconnectWait);
      } else if (reconnectChoice === '2') {
          console.log(c.yellow + c.bold + `🔄 [Bedrock] Same naam (${username}) ke sath normal Reconnect (${reconnectWait/1000}s me)...` + c.reset);
          setTimeout(() => launchBedrockBot(ip, port, username, version, reconnectChoice, suffixChoice, baseName, speedChoice), reconnectWait);
      }
  })
  client.on('error', (err) => console.log(c.yellow + c.bold + `⚠️ [Bedrock] ${username} Error: ${err.message}` + c.reset))
}

startInteractiveMenu()
