    } 
    
    else if (step === 2) {
      console.log(c.yellow + c.bold + 'Q2. Deployment Mode:' + c.reset)
      console.log(c.cyan + '(1) Limited bots | (2) Unlimited bots | (3) Back' + c.reset)
      modeChoice = (await ask(c.green + c.bold + 'Choice-» ' + c.reset)).trim()
      
      if (modeChoice === '3') step--;
      else if (['1','2'].includes(modeChoice)) {
